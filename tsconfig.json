{
  "compilerOptions": {
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "baseUrl": "./",
    "paths": {
      "@/*": ["packages/*"],
      "@@/*": [".dumi/tmp/*"],
      "@OrinUI/components": ["packages/components/src"],
      "@OrinUI/components/*": ["packages/components/src/*"],
      "@OrinUI/hooks": ["packages/hooks/src"],
      "@OrinUI/hooks/*": ["packages/hooks/src/*"],
      "@OrinUI/utils": ["packages/utils/src"],
      "@OrinUI/utils/*": ["packages/utils/src/*"],
      "@OrinUI/ai-skills": ["packages/ai-skills/src"],
      "@OrinUI/ai-skills/*": ["packages/ai-skills/src/*"]
    }
  },
  "references": [
    { "path": "./packages/components" },
    { "path": "./packages/hooks" },
    { "path": "./packages/utils" },
    { "path": "./packages/ai-skills" }
  ],
  "include": [".dumirc.ts", ".fatherrc.ts", "src/**/*", "docs/**/*"]
}
